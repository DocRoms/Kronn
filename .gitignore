# Playwright MCP transient logs (~117MB of session console dumps —
# accidentally absorbed by the wip commit at 18:36 on 2026-05-09).
# Never commit; clean up uncommitted with `git rm --cached -r .playwright-mcp/`.
.playwright-mcp/
.kronn/tmp/

# Coverage reports — generated by vitest --coverage + cargo llvm-cov.
# NEVER commit these: lcov-report/ alone is ~hundreds of KB of HTML per run,
# and the lcov.info file changes on every test run. The CI runs coverage
# fresh anyway, so committing it just churns git history.
frontend/coverage/
backend/coverage/
.rtk/
