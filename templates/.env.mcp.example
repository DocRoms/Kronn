# MCP Servers — Environment variables
# Copy this file to .env.mcp and fill in your values:
#   cp .env.mcp.example .env.mcp
#
# Then generate MCP config:
#   make mcp-gen
#
# See ai/operations/mcp-servers.md for full setup guide.

# ─── Atlassian (Jira + Confluence) ────────────────────────────────
# Personal credentials — each dev uses their own (Jira traceability)
ATLASSIAN_URL=https://euronews.atlassian.net
JIRA_USERNAME=prenom.nom@euronews.com
JIRA_API_TOKEN=
CONFLUENCE_USERNAME=prenom.nom@euronews.com
CONFLUENCE_API_TOKEN=

# ─── GitHub ──────────────────────────────────────────────────────
# Personal Access Token (fine-grained recommended)
# Create at: https://github.com/settings/tokens?type=beta
# Resource owner: Euronews-tech | Repo access: All | Permissions: Contents=Read, Metadata=Read
GITHUB_PERSONAL_ACCESS_TOKEN=
