    banner
    printf "${BOLD}Usage:${RESET} kronn [command]\n"
    echo
    printf "  ${CYAN}start${RESET}          Interactive flow (default)\n"
    printf "  ${CYAN}start-dev${RESET}      Run natively, no Docker (backend + Vite, hot-reload → UI on :5173)\n"
